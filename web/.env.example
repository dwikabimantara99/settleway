# Settleway web environment example.
# Copy to .env.local for local work. Do not commit real values.

# Runtime mode: test, demo, or persistent.
NEXT_PUBLIC_RUNTIME_MODE=demo

# Supabase persistent mode. Required only when runtime mode is persistent.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo reset safety switch. Keep disabled outside local/demo use.
ENABLE_DEMO_RESET=false

# Optional Testnet smoke/operator configuration.
SETTLEWAY_SMOKE_COMMAND=
SETTLEWAY_SMOKE_ACKNOWLEDGEMENT=
SETTLEWAY_SMOKE_CHECKPOINT_COMMIT=
SETTLEWAY_SMOKE_RPC_URL=https://soroban-testnet.stellar.org
SETTLEWAY_SMOKE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SETTLEWAY_SMOKE_CONTRACT_ID=
SETTLEWAY_SMOKE_ADMIN_ADDRESS=
SETTLEWAY_SMOKE_BUYER_DEMO_ADDRESS=
SETTLEWAY_SMOKE_SELLER_DEMO_ADDRESS=
SETTLEWAY_SMOKE_STELLAR_CLI_PATH=
SETTLEWAY_SMOKE_STELLAR_CONFIG_DIR=
SETTLEWAY_SMOKE_STELLAR_NETWORK_ALIAS=
SETTLEWAY_SMOKE_ADMIN_KEY_ALIAS=
SETTLEWAY_SMOKE_BUYER_DEMO_KEY_ALIAS=
SETTLEWAY_SMOKE_SELLER_DEMO_KEY_ALIAS=
SETTLEWAY_SMOKE_BASE_FEE_STROOPS=100
SETTLEWAY_SMOKE_MAX_FEE_STROOPS=100000
SETTLEWAY_SMOKE_TIMEOUT_SECONDS=30
SETTLEWAY_SMOKE_CONFIRMATION_ATTEMPTS=5
